<Window x:Class="Assistent.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Assistent.App.ViewModels"
        xmlns:conv="clr-namespace:Assistent.App.Converters"
        mc:Ignorable="d"
        Title="Assistent"
        Height="680" Width="980"
        MinHeight="420" MinWidth="560"
        Background="{DynamicResource Brush.WindowBackground}"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <conv:ChatRoleToAlignmentConverter x:Key="RoleAlign" />
        <conv:InverseBooleanConverter x:Key="InverseBool" />
        <conv:StringEmptyToVisibilityConverter x:Key="EmptyToVis" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="StatusBannerStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Success}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusBannerIsError}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Brush.Error}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ChatBubbleBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.AssistantBubble}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.AssistantBubbleBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="MaxWidth" Value="560" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.18" Color="#000000" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Role}" Value="{x:Static vm:ChatRole.User}">
                    <Setter Property="Background" Value="{DynamicResource Brush.UserBubble}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.UserBubbleBorder}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="ToolbarButton">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceElevated}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        </Style>
        <Style TargetType="Button" x:Key="PrimaryButton" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="{DynamicResource Brush.Primary}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Primary}" />
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16,12"
                Margin="0,0,0,12">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Theme"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding ToggleThemeCommand}"
                            ToolTip="Cycle light / dark / system" />
                    <Button Content="Ollama"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding CheckHealthCommand}" />
                    <Button Content="Settings"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenSettingsCommand}" />
                    <Button Content="New chat"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding NewChatCommand}" />
                    <Button Content="Export"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding ExportChatCommand}" />
                    <Button Content="Stop"
                            Style="{StaticResource ToolbarButton}"
                            IsEnabled="{Binding IsBusy}"
                            Command="{Binding CancelSendCommand}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Assistent"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextPrimary}" />
                    <TextBlock Text="Local Windows assistant"
                               FontSize="12"
                               Foreground="{DynamicResource Brush.TextSecondary}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <TextBlock Grid.Row="1"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   FontSize="12"
                   Foreground="{DynamicResource Brush.TextSecondary}"
                   Text="PowerShell execution and related safeguards are configured in Settings." />

        <!-- Chat card -->
        <Border Grid.Row="2"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="10">
            <ListBox x:Name="ChatList"
                     ItemsSource="{Binding Messages}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.CanContentScroll="False"
                     VirtualizingStackPanel.IsVirtualizing="False">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="6" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ChatLine}">
                        <Border Style="{StaticResource ChatBubbleBorderStyle}"
                                HorizontalAlignment="{Binding Role, Converter={StaticResource RoleAlign}}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,6"
                                            Visibility="{Binding IsAwaitingResponse, Converter={StaticResource BoolToVis}}">
                                    <ProgressBar Width="120"
                                                 Height="4"
                                                 IsIndeterminate="True"
                                                 VerticalAlignment="Center" />
                                    <TextBlock Text="Getting a response…"
                                               Margin="10,0,0,0"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.TextSecondary}" />
                                </StackPanel>
                                <Expander Header="Reasoning"
                                          IsExpanded="True"
                                          Margin="0,0,0,6"
                                          Visibility="{Binding ThinkingText, Converter={StaticResource EmptyToVis}}">
                                    <TextBlock Text="{Binding ThinkingText}"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{DynamicResource Brush.TextSecondary}" />
                                </Expander>
                                <TextBlock Text="{Binding Text}"
                                           TextWrapping="Wrap"
                                           FontSize="14"
                                           Foreground="{DynamicResource Brush.TextPrimary}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusBanner}"
                   Style="{StaticResource StatusBannerStyle}"
                   TextWrapping="Wrap"
                   Margin="0,10,0,6"
                   Visibility="{Binding StatusBanner, Converter={StaticResource EmptyToVis}}" />

        <!-- Composer -->
        <Border Grid.Row="4"
                Background="{DynamicResource Brush.SurfaceElevated}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="10"
                Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         x:Name="Composer"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="48"
                         MaxHeight="160"
                         Padding="12,10"
                         VerticalScrollBarVisibility="Auto"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"
                         Background="{DynamicResource Brush.InputBackground}"
                         Foreground="{DynamicResource Brush.TextPrimary}"
                         BorderBrush="{DynamicResource Brush.Border}"
                         CaretBrush="{DynamicResource Brush.TextPrimary}" />
                <Button Grid.Column="1"
                        Content="Send"
                        Style="{StaticResource PrimaryButton}"
                        Margin="10,0,0,0"
                        VerticalAlignment="Bottom"
                        Padding="22,12"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Command="{Binding SendCommand}" />
            </Grid>
        </Border>
    </Grid>
</Window>
