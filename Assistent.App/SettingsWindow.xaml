<Window x:Class="Assistent.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:settings="clr-namespace:Assistent.App.Settings"
        mc:Ignorable="d"
        Title="Settings"
        Width="480"
        Height="Auto"
        SizeToContent="Height"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.WindowBackground}"
        Foreground="{DynamicResource Brush.TextPrimary}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <TextBlock Text="Assistent" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />

            <TextBlock Text="Assistant provider" FontWeight="SemiBold" />
            <TextBlock Text="{Binding ProviderDisplay}" Margin="0,4,0,12"
                       Foreground="{DynamicResource Brush.TextSecondary}" />

            <TextBlock Text="LlamaSharp (local GGUF)" FontWeight="SemiBold" />
            <TextBlock Text="Models folder" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,4,0,0" />
            <TextBlock Text="{Binding LlamaSharpModelsFolderDisplay}" TextWrapping="Wrap" Margin="0,0,0,8"
                       Foreground="{DynamicResource Brush.TextPrimary}" FontFamily="Consolas" />
            <TextBlock Text="Active model" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" />
            <TextBlock Text="{Binding LlamaSharpModelPathDisplay}" TextWrapping="Wrap" Margin="0,0,0,12"
                       Foreground="{DynamicResource Brush.TextPrimary}" FontFamily="Consolas" />

            <TextBlock Text="Theme" FontWeight="SemiBold" />
            <ComboBox Margin="0,4,0,12"
                      SelectedItem="{Binding Preferences.Theme, Mode=TwoWay}"
                      Background="{DynamicResource Brush.InputBackground}"
                      Foreground="{DynamicResource Brush.TextPrimary}"
                      BorderBrush="{DynamicResource Brush.Border}">
                <ComboBox.ItemsSource>
                    <x:Array Type="settings:AppTheme">
                        <settings:AppTheme>Light</settings:AppTheme>
                        <settings:AppTheme>Dark</settings:AppTheme>
                        <settings:AppTheme>System</settings:AppTheme>
                    </x:Array>
                </ComboBox.ItemsSource>
            </ComboBox>

            <TextBlock Text="Ollama base URL (override)" FontWeight="SemiBold" />
            <TextBox Text="{Binding Preferences.OllamaBaseUrlOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,4,0,4"
                     Background="{DynamicResource Brush.InputBackground}"
                     Foreground="{DynamicResource Brush.TextPrimary}"
                     BorderBrush="{DynamicResource Brush.Border}" />
            <TextBlock Text="Leave empty to use appsettings.json" FontSize="11"
                       Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,12" />

            <TextBlock Text="Ollama model (override)" FontWeight="SemiBold" />
            <TextBox Text="{Binding Preferences.OllamaModelOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,4,0,4"
                     Background="{DynamicResource Brush.InputBackground}"
                     Foreground="{DynamicResource Brush.TextPrimary}"
                     BorderBrush="{DynamicResource Brush.Border}" />
            <TextBlock Text="Leave empty for default model from appsettings" FontSize="11"
                       Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,12" />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="Ollama request timeout (seconds, 0 = default " FontWeight="SemiBold" />
                <TextBlock Text="{Binding DefaultOllamaTimeoutDisplay, Mode=OneWay}" FontWeight="SemiBold" />
                <TextBlock Text=")" FontWeight="SemiBold" />
            </StackPanel>
            <TextBox Text="{Binding Preferences.OllamaRequestTimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,4,0,4"
                     Background="{DynamicResource Brush.InputBackground}"
                     Foreground="{DynamicResource Brush.TextPrimary}"
                     BorderBrush="{DynamicResource Brush.Border}" />

            <CheckBox Content="Ollama thinking mode (separate reasoning trace)"
                      IsChecked="{Binding Preferences.OllamaThink, Mode=TwoWay}"
                      Margin="0,4,0,4" />
            <TextBlock Text="Turn off for a direct answer only (Qwen3 and similar). Default follows appsettings Ollama:Think."
                       FontSize="11"
                       Foreground="{DynamicResource Brush.TextSecondary}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12" />

            <TextBlock Text="Conversation" FontWeight="SemiBold" />
            <TextBlock Text="Max messages kept (including system)" FontSize="12" Margin="0,4,0,0"
                       Foreground="{DynamicResource Brush.TextSecondary}" />
            <TextBox Text="{Binding Preferences.MaxConversationMessages, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,4,0,12"
                     Background="{DynamicResource Brush.InputBackground}"
                     Foreground="{DynamicResource Brush.TextPrimary}"
                     BorderBrush="{DynamicResource Brush.Border}" />

            <TextBlock Text="PowerShell tool" FontWeight="SemiBold" Margin="0,8,0,0" />
            <CheckBox Content="Allow execute_powershell"
                      IsChecked="{Binding Preferences.AllowPowerShellExecution, Mode=TwoWay}"
                      Margin="0,8,0,0" />
            <CheckBox Content="Confirm before each PowerShell command"
                      IsChecked="{Binding Preferences.ConfirmBeforePowerShell, Mode=TwoWay}"
                      Margin="0,4,0,0" />
            <TextBlock Text="Allowlist prefix (optional)" Margin="0,12,0,0" FontWeight="SemiBold" />
            <TextBox Text="{Binding Preferences.PowerShellAllowlistPrefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,4,0,0"
                     Background="{DynamicResource Brush.InputBackground}"
                     Foreground="{DynamicResource Brush.TextPrimary}"
                     BorderBrush="{DynamicResource Brush.Border}" />
            <TextBlock Text="When set, commands must start with this prefix (case-insensitive)." FontSize="11"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,4,0,16" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Padding="20,8" Margin="0,0,8,0" IsDefault="True" Click="Ok_OnClick"
                        Background="{DynamicResource Brush.Primary}"
                        Foreground="White"
                        BorderBrush="{DynamicResource Brush.Primary}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
